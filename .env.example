APP_NAME="Express Payments"
APP_DESCRIPTION="Plataforma Express Payments para gestão de estabelecimentos, faturamento EDI PagBank, comissões e operações de maquininhas."
APP_KEYWORDS="Express Payments, PagBank, maquininha, faturamento, comissões, EDI"
APP_ROBOTS="noindex, nofollow"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://express.app.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ── Banco de dados ────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=express
DB_USERNAME=express
DB_PASSWORD=senha_segura_aqui
DB_ROOT_PASSWORD=root_senha_segura_aqui

# ── Sessão, Cache e Filas ─────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# ── Email (SMTP) ──────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.seudominio.com.br
MAIL_PORT=587
MAIL_USERNAME=noreply@seudominio.com.br
MAIL_PASSWORD=senha_email
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@seudominio.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# ── PagBank EDI ───────────────────────────────────────────────────
PAGBANK_EDI_URL=https://edi.api.pagbank.com.br
PAGBANK_EDI_TOKEN=

# ── PagBank — API de cadastro de contas (parceiro) ────────────────
# Configurável também em Admin → Configurações → PagBank
PAGBANK_TOKEN=
PAGBANK_CLIENT_ID=
PAGBANK_CLIENT_SECRET=
PAGBANK_AMBIENTE=producao
# PAGBANK_API_URL=https://sandbox.api.pagseguro.com

# ── DirectAdmin / Webmail ─────────────────────────────────────────
DIRECTADMIN_URL=https://72.62.181.162:2222
DIRECTADMIN_USER=admin
DIRECTADMIN_PASS=SUA_LOGIN_KEY_AQUI
DIRECTADMIN_DOMINIO=express.app.br
DIRECTADMIN_WEBMAIL_URL=https://mail.express.app.br/roundcube
DIRECTADMIN_IMAP_HOST=mail.express.app.br
DIRECTADMIN_IMAP_PORT=993
DIRECTADMIN_SMTP_HOST=mail.express.app.br
DIRECTADMIN_SMTP_PORT=587
DIRECTADMIN_AUTO_EMAIL=true
EMAIL_DEMO_LAYOUT=false

# ── KYC — OpenAI Vision ───────────────────────────────────────────
# Configurável também em Admin → Configurações → KYC
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
BRASILAPI_URL=https://brasilapi.com.br/api

# ── Tenant / Domínios ─────────────────────────────────────────────
TENANT_BASE_DOMAIN=seudominio.com.br
TENANT_PLATFORM_HOSTS=localhost,127.0.0.1
TENANT_PROVISION_SUBDOMAIN=false
TENANT_LOCAL_QUERY=tenant

# ── Automação PagBank — Força de Vendas ───────────────────────────
# Container Docker interno — acesso via nome do serviço
AUTOMACAO_API_URL=http://automacao:8001
# Deve ser a mesma chave do automacao/.env (AUTOMACAO_API_KEY)
AUTOMACAO_API_KEY=

# Credenciais do portal Força de Vendas PagBank
AUTOMACAO_FV_USUARIO=
AUTOMACAO_FV_SENHA=

# URL do webmail Roundcube (igual para todos os clientes)
# Email e senha individuais de cada cliente ficam no banco de dados
AUTOMACAO_WEBMAIL_URL=https://mail.seudominio.com.br

# Configurações de comportamento
AUTOMACAO_AGUARDAR_EMAIL_SEG=90
AUTOMACAO_POLLING_INTERVALO=20
AUTOMACAO_POLLING_MAX=30
AUTOMACAO_HEADLESS=true
